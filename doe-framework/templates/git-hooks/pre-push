#!/usr/bin/env bash

# =============================================================================
# pre-push hook — Local CI gate (stand-in while remote CI is unavailable)
# =============================================================================
#
# Part of the D.O.E. Framework (Direttiva, Orchestrazione, Esecuzione)
#
# PURPOSE:
#   Run the deterministic quality gates locally before every `git push`, so
#   regressions are caught even when the remote CI (GitHub Actions / Gitea
#   Actions) is not running. Mirrors the blocking checks of `.gitea/workflows/
#   ci.yml` / `.github/workflows/ci.yml`.
#
# CHECKS (in order):
#   1. cargo +nightly fmt --all --check    (REPORT-ONLY; see "Known debt")
#   2. cargo clippy (workspace)            (REPORT-ONLY on warnings; BLOCKS only
#                                           on real compile errors — see debt)
#   3. cargo test --workspace              (BLOCKING; omni-kernel excluded, its
#                                           --lib tests SIGSEGV on x86_64 Linux
#                                           dev hosts — a known host-only issue)
#   4. cargo deny: bans/licenses/sources   (BLOCKING if cargo-deny installed;
#      advisories                            advisories REPORT-ONLY — stale
#                                            advisory-db parse issue, see below)
#
# ESCAPE HATCHES:
#   - `git push --no-verify`        → skip this hook entirely (one-off)
#   - `OMNI_SKIP_PREPUSH=1 git push`→ skip this hook entirely
#   - `OMNI_PREPUSH_FAST=1 git push`→ skip the (slow) test + deny steps
#
# Known debt (2026-05-29, accumulated while remote CI was down):
#   - `cargo +nightly fmt --all --check` reports ~692 diffs across many crates
#     (omni-agent et al.). The canonical formatter is NIGHTLY rustfmt
#     (rustfmt.toml uses nightly-only options: imports_granularity,
#     group_imports, format_code_in_doc_comments). Until a repo-wide
#     `cargo +nightly fmt --all` cleanup commit lands, fmt here is REPORT-ONLY.
#   - `cargo clippy --workspace -- -D warnings` reports ~82 pre-existing
#     violations in Sprint-10 files. Until cleared, clippy is REPORT-ONLY
#     (blocks only on real compile errors).
# Re-enable strict mode for each (uncomment the marked blocks) once its debt
# is zero, to make this hook a true equivalent of the CI gate.
# =============================================================================

set -uo pipefail

if [[ "${OMNI_SKIP_PREPUSH:-0}" == "1" ]]; then
    echo "  [pre-push] OMNI_SKIP_PREPUSH=1 — skipping local gate."
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

log()  { echo "  [pre-push] $*"; }
fail() { echo "  [pre-push] ✗ $*" >&2; echo "  [pre-push] (bypass with: git push --no-verify)" >&2; exit 1; }
ok()   { echo "  [pre-push] ✓ $*"; }

echo ""
echo "  ── OMNI OS local CI gate ───────────────────────────────────"

# ---------------------------------------------------------------------------
# 1. Formatting (REPORT-ONLY — canonical formatter is nightly rustfmt)
# ---------------------------------------------------------------------------
FMT="cargo fmt"
if rustup component list --toolchain nightly 2>/dev/null | grep -q 'rustfmt.*(installed)'; then
    FMT="cargo +nightly fmt"
fi
log "${FMT} --all -- --check (report-only) ..."
$FMT --all -- --check >/tmp/omni-prepush-fmt.log 2>&1 || true
FMT_DIFFS="$(grep -c 'Diff in' /tmp/omni-prepush-fmt.log || true)"
if [[ "$FMT_DIFFS" -gt 0 ]]; then
    log "⚠ formatting: ${FMT_DIFFS} file-region diffs (pre-existing debt — not blocking)"
    log "  to normalize: ${FMT} --all   (see /tmp/omni-prepush-fmt.log)"
else
    ok "formatting clean"
fi
# --- Strict mode (enable when fmt debt == 0): --------------------------------
# if ! $FMT --all -- --check >/tmp/omni-prepush-fmt.log 2>&1; then
#     cat /tmp/omni-prepush-fmt.log >&2
#     fail "formatting check failed — run '${FMT} --all'."
# fi
# -----------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# 2. Clippy (REPORT-ONLY — pre-existing deny-level errors in omni-hal + ~82
#    -D-warnings violations across Sprint-10 files; see "Known debt")
# ---------------------------------------------------------------------------
log "cargo clippy --workspace --all-targets --all-features (report-only) ..."
cargo clippy --workspace --all-targets --all-features >/tmp/omni-prepush-clippy.log 2>&1 || true
CLIPPY_ERR="$(grep -cE '^error' /tmp/omni-prepush-clippy.log || true)"
CLIPPY_WARN="$(grep -cE '^warning' /tmp/omni-prepush-clippy.log || true)"
if [[ "$CLIPPY_ERR" -gt 0 ]]; then
    log "⚠ clippy: ${CLIPPY_ERR} errors / ${CLIPPY_WARN} warnings (pre-existing debt — not blocking)"
    log "  details: /tmp/omni-prepush-clippy.log"
else
    ok "clippy clean (warnings: ${CLIPPY_WARN})"
fi
# --- Strict mode (enable when clippy debt == 0): -----------------------------
# if ! cargo clippy --workspace --all-targets --all-features -- -D warnings \
#       >/tmp/omni-prepush-clippy.log 2>&1; then
#     cat /tmp/omni-prepush-clippy.log >&2
#     fail "clippy -D warnings failed."
# fi
# -----------------------------------------------------------------------------

if [[ "${OMNI_PREPUSH_FAST:-0}" == "1" ]]; then
    log "OMNI_PREPUSH_FAST=1 — skipping test + deny steps."
    echo "  ────────────────────────────────────────────────────────────"
    echo ""
    exit 0
fi

# ---------------------------------------------------------------------------
# 3. Tests (blocking; omni-kernel excluded — see header)
# ---------------------------------------------------------------------------
log "cargo test --workspace --exclude omni-kernel ..."
if ! cargo test --workspace --exclude omni-kernel >/tmp/omni-prepush-test.log 2>&1; then
    tail -40 /tmp/omni-prepush-test.log >&2
    fail "tests failed (full log: /tmp/omni-prepush-test.log)."
fi
ok "tests pass (omni-kernel --lib excluded: known host SIGSEGV)"

# ---------------------------------------------------------------------------
# 4. Dependency policy (blocking if cargo-deny present)
# ---------------------------------------------------------------------------
if command -v cargo-deny >/dev/null 2>&1; then
    # `advisories` is REPORT-ONLY: the local advisory-db may contain newer
    # RUSTSEC entries (CVSS 4.0) that an older cargo-deny cannot parse — a
    # tooling-version issue, not a project vulnerability. Upgrade with
    # `cargo install cargo-deny` to make advisories enforceable again.
    log "cargo deny check advisories (report-only) ..."
    cargo deny check advisories >/tmp/omni-prepush-deny-adv.log 2>&1 || \
        log "⚠ advisories check non-clean (see /tmp/omni-prepush-deny-adv.log; often stale cargo-deny)"

    # bans / licenses / sources are project-controlled → BLOCKING.
    log "cargo deny check bans licenses sources ..."
    if ! cargo deny check bans licenses sources >/tmp/omni-prepush-deny.log 2>&1; then
        tail -40 /tmp/omni-prepush-deny.log >&2
        fail "cargo deny (bans/licenses/sources) failed (full log: /tmp/omni-prepush-deny.log)."
    fi
    ok "cargo deny bans/licenses/sources clean"
else
    log "cargo-deny not installed — skipping (install: cargo install cargo-deny)"
fi

echo "  ── all local gates passed ──────────────────────────────────"
echo ""
exit 0
