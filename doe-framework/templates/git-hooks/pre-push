#!/usr/bin/env bash

# =============================================================================
# pre-push hook — Local CI gate
# =============================================================================
#
# Part of the D.O.E. Framework (Direttiva, Orchestrazione, Esecuzione)
#
# PURPOSE:
#   Run the deterministic quality gates locally before every `git push`, so
#   regressions are caught immediately. Mirrors the blocking checks of
#   `.github/workflows/ci.yml`.
#
# CHECKS (all BLOCKING):
#   1. cargo fmt --all -- --check                  (stable rustfmt — matches CI)
#   2. cargo clippy --workspace --all-targets
#      --all-features -- -D warnings               (debt cleared 2026-05-29)
#   3. cargo test --workspace --exclude omni-kernel (omni-kernel --lib tests
#                                                    SIGSEGV on x86_64 Linux dev
#                                                    hosts — known host issue)
#   4. cargo deny check                            (advisories+bans+licenses+
#                                                    sources; needs cargo-deny)
#
# ESCAPE HATCHES:
#   - `git push --no-verify`        → skip this hook entirely (one-off)
#   - `OMNI_SKIP_PREPUSH=1 git push`→ skip this hook entirely
#   - `OMNI_PREPUSH_FAST=1 git push`→ skip the (slow) test + deny steps
#
# NOTES:
#   - The CI fmt job uses STABLE rustfmt; rustfmt.toml's nightly-only options
#     (imports_granularity, group_imports, format_code_in_doc_comments) are
#     ignored on stable, so the canonical format is stable-rustfmt output. Use
#     plain `cargo fmt` (NOT `+nightly`) to match CI.
#   - cargo-deny must be a build that parses CVSS-4.0 RUSTSEC entries
#     (>= the rustsec bump in cargo-deny 0.19; build via a recent toolchain,
#     e.g. `cargo +nightly install cargo-deny --locked`). Older builds choke on
#     advisory-db entries with `cvss = "CVSS:4.0/..."`.
# =============================================================================

set -uo pipefail

if [[ "${OMNI_SKIP_PREPUSH:-0}" == "1" ]]; then
    echo "  [pre-push] OMNI_SKIP_PREPUSH=1 — skipping local gate."
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

log()  { echo "  [pre-push] $*"; }
fail() { echo "  [pre-push] ✗ $*" >&2; echo "  [pre-push] (bypass with: git push --no-verify)" >&2; exit 1; }
ok()   { echo "  [pre-push] ✓ $*"; }

echo ""
echo "  ── OMNI OS local CI gate ───────────────────────────────────"

# ---------------------------------------------------------------------------
# 1. Formatting (BLOCKING — stable rustfmt, matches CI)
# ---------------------------------------------------------------------------
log "cargo fmt --all -- --check ..."
if ! cargo fmt --all -- --check >/tmp/omni-prepush-fmt.log 2>&1; then
    grep "Diff in" /tmp/omni-prepush-fmt.log >&2 || cat /tmp/omni-prepush-fmt.log >&2
    fail "formatting check failed — run 'cargo fmt --all'."
fi
ok "formatting clean"

# ---------------------------------------------------------------------------
# 2. Clippy (BLOCKING — -D warnings, matches CI)
# ---------------------------------------------------------------------------
log "cargo clippy --workspace --all-targets --all-features -- -D warnings ..."
if ! cargo clippy --workspace --all-targets --all-features -- -D warnings \
      >/tmp/omni-prepush-clippy.log 2>&1; then
    grep -E '^(error|warning)' /tmp/omni-prepush-clippy.log | head -40 >&2
    fail "clippy -D warnings failed (full log: /tmp/omni-prepush-clippy.log)."
fi
ok "clippy clean (-D warnings)"

if [[ "${OMNI_PREPUSH_FAST:-0}" == "1" ]]; then
    log "OMNI_PREPUSH_FAST=1 — skipping test + deny steps."
    echo "  ────────────────────────────────────────────────────────────"
    echo ""
    exit 0
fi

# ---------------------------------------------------------------------------
# 3. Tests (BLOCKING; omni-kernel excluded — see header)
# ---------------------------------------------------------------------------
log "cargo test --workspace --exclude omni-kernel ..."
if ! cargo test --workspace --exclude omni-kernel >/tmp/omni-prepush-test.log 2>&1; then
    tail -40 /tmp/omni-prepush-test.log >&2
    fail "tests failed (full log: /tmp/omni-prepush-test.log)."
fi
ok "tests pass (omni-kernel --lib excluded: known host SIGSEGV)"

# ---------------------------------------------------------------------------
# 4. Dependency policy (BLOCKING — advisories + bans + licenses + sources)
# ---------------------------------------------------------------------------
if command -v cargo-deny >/dev/null 2>&1; then
    log "cargo deny check ..."
    if ! cargo deny check >/tmp/omni-prepush-deny.log 2>&1; then
        tail -40 /tmp/omni-prepush-deny.log >&2
        fail "cargo deny check failed (full log: /tmp/omni-prepush-deny.log)."
    fi
    ok "cargo deny check clean (advisories/bans/licenses/sources)"
else
    log "cargo-deny not installed — skipping (install: cargo +nightly install cargo-deny --locked)"
fi

echo "  ── all local gates passed ──────────────────────────────────"
echo ""
exit 0
