# =============================================================================
# D.O.E. Framework — .gitignore Template: Python
# Generated: <YYYY-MM-DD>
# Base: gitignore.io/api/python + D.O.E. security rules
# =============================================================================

# --- Secrets and credentials (NEVER commit) ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
service-account.json
**/secrets/

# --- Agent-specific files (NEVER commit) ---
CLAUDE.md
.cursorrules
.cursor/
.aider*
copilot-*

# --- OS-generated files ---
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- IDE and editor files ---
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- Temporary and generated files ---
tmp/
temp/
.tmp/
*.log
*.bak
*.orig

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual environments ---
.venv/
venv/
ENV/
env/

# --- Testing ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.nox/
.tox/

# --- Distribution / packaging ---
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# --- Jupyter Notebook ---
.ipynb_checkpoints

# --- Celery ---
celerybeat-schedule
celerybeat.pid

# --- Database ---
*.db
*.sqlite3
