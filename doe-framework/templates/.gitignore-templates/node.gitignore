# =============================================================================
# D.O.E. Framework — .gitignore Template: JavaScript / TypeScript (Node.js)
# Generated: <YYYY-MM-DD>
# Base: gitignore.io/api/node + D.O.E. security rules
# =============================================================================

# --- Secrets and credentials (NEVER commit) ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
service-account.json
**/secrets/

# --- Agent-specific files (NEVER commit) ---
CLAUDE.md
.cursorrules
.cursor/
.aider*
copilot-*

# --- OS-generated files ---
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- IDE and editor files ---
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- Temporary and generated files ---
tmp/
temp/
.tmp/
*.log
*.bak
*.orig

# --- Node.js ---
node_modules/
.npm
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# --- Build output ---
dist/
build/
out/
.next/
.nuxt/
.output/
.cache/
.parcel-cache/

# --- TypeScript ---
*.tsbuildinfo

# --- Testing ---
coverage/
.nyc_output/
.eslintcache

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Runtime data ---
pids
*.pid
*.seed
*.pid.lock
