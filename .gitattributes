# =============================================================================
# OMNI OS — gitattributes
# =============================================================================
# Normalize line endings to LF in the repo regardless of contributor OS, and
# keep binary files from being mangled by line-ending heuristics.
# =============================================================================

# --- Default: text auto-detect, normalize to LF ---------------------------
* text=auto eol=lf

# --- Source code (explicit) -----------------------------------------------
*.rs       text eol=lf diff=rust
*.toml     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.sh       text eol=lf
*.py       text eol=lf

# Shell scripts must always be LF even on Windows checkouts.
*.sh       text eol=lf
scripts/*  text eol=lf

# --- Binary files ---------------------------------------------------------
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.tar.gz   binary
*.tgz      binary
*.7z       binary
*.bin      binary
*.gguf     binary
*.safetensors binary
*.pt       binary
*.onnx     binary

# Cargo lockfile is text but we want a stable diff for review.
Cargo.lock text eol=lf -diff
